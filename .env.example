# ===== AI Mufti frontend environment =====
# Copy to .env.local and fill with your OWN values. Never commit .env.local.

# Better Auth — generate a secret with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=your_random_32_byte_hex_secret
BETTER_AUTH_URL=http://localhost:3000

# Postgres (Neon) — auth runs server-side in Next, so it needs the DB.
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# FastAPI backend URL
NEXT_PUBLIC_API_URL=https://your-backend.hf.space
